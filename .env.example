# Web3Forms access key for the Contact Us form.
# Get a key at https://web3forms.com (see README for business steps).
# Copy this file to `.env` and paste the key:
VITE_WEB3FORMS_ACCESS_KEY=

# Optional: canonical site URL for SEO (Open Graph, JSON-LD). Defaults to https://inselbergsolutions.com
# VITE_SITE_URL=https://inselbergsolutions.com
